INSERT INTO articles (user_id, category_id, title, summary, content, cover, source, views, status, published_at, created_at, updated_at) VALUES
(1, 1, '河北信鸽赛事2026赛季全面解读',
'河北省2026年信鸽赛事数据全解析：涵盖石家庄、唐山、保定等主要城市公棚赛绩，分速排行与鸽主成绩一览。',
'<h2>河北省信鸽赛事概览</h2>
<p>河北省作为中国信鸽运动大省，2026年赛季共收录 <strong>超过200场</strong> 公棚与协会赛事数据。信鸽之家数据库覆盖石家庄、唐山、保定、邯郸、廊坊等主要城市，为鸽友提供全面翔实的赛事参考。</p>
<p>👉 <a href="/race/province/河北/">查看河北全部赛事数据 →</a></p>
<h2>热门公棚推荐</h2>
<p>河北省拥有众多优质公棚，其中唐山、廊坊地区的公棚因参赛羽数大、赛线公平而备受鸽友青睐。建议鸽友在选择公棚时重点关注：</p>
<ul>
<li><strong>历史赛绩</strong>：公棚历年比赛分速数据是否稳定</li>
<li><strong>参赛规模</strong>：大羽数赛事更具含金量</li>
<li><strong>地理位置</strong>：赛线是否适合自己的鸽系</li>
</ul>
<p>🔍 <a href="/loft/province/河北/">浏览河北全部公棚 →</a></p>
<h2>2026赛季特征</h2>
<p>今年河北赛事整体呈现"高羽数、高分速"的特点。春赛期间多场赛事参赛羽数突破5000羽，分速中位数较往年有所提升。建议鸽友关注 <a href="/tools.php?action=top100">TOP100分速排行榜</a> 追踪最新数据。</p>
<p>📌 更多省份赛事分析请访问 <a href="/">信鸽之家首页</a> 进行足环号查询。</p>',
'images/articles/article_b3_01.svg', '信鸽之家数据引擎'),

(1, 1, '山东信鸽赛事2026赛季成绩深度分析',
'山东省2026信鸽赛事数据库报告：济南、青岛等16地市公棚赛绩对比，分速与空距分布规律。',
'<h2>山东——赛鸽第一大省</h2>
<p>山东省信鸽运动历史悠久，2026年赛季赛事数据量位居全国前列。信鸽之家收录山东省 <strong>16个地市</strong> 的公棚与协会赛事成绩，涵盖济南、青岛、烟台、潍坊、临沂等主要赛区。</p>
<p>👉 <a href="/race/province/山东/">查看山东全部赛事数据 →</a></p>
<h2>赛线特点</h2>
<p>山东省地势以平原为主，赛线难度相对较低，因而分速整体偏高。但沿海城市（青岛、烟台、威海）受海风影响，赛事结果存在一定不确定性，鸽友选鸽时需考虑抗风能力。</p>
<h2>2026热门赛区</h2>
<ul>
<li><strong>济南赛区</strong>：参赛羽数最大，竞争最激烈</li>
<li><strong>潍坊赛区</strong>：分速水平高，多次出现1700+分速</li>
<li><strong>临沂赛区</strong>：山区赛线，考验鸽子定向能力</li>
</ul>
<p>🔍 <a href="/loft/province/山东/">浏览山东全部公棚 →</a></p>
<p>使用 <a href="/">足环号查询工具</a> 输入任意山东赛鸽足环号，查看完整参赛记录。</p>',
'images/articles/article_b3_02.svg', '信鸽之家数据引擎'),

(1, 1, '北京信鸽赛事2026年度数据报告',
'2026年北京信鸽赛事成绩汇总：天安门、大兴、顺义等赛区数据分析，冠军鸽分速与血统统计。',
'<h2>首都赛鸽年度报告</h2>
<p>北京作为全国信鸽运动的中心城市，2026年举办了 <strong>百余场</strong> 高规格赛事。信鸽之家数据库完整收录了这些赛事成绩，为鸽友提供权威数据参考。</p>
<p>👉 <a href="/race/city/北京/">查看北京全部赛事数据 →</a></p>
<h2>京城赛事特色</h2>
<p>北京赛事以公棚赛为主，春赛和秋赛两季分明。主要特点：</p>
<ul>
<li><strong>参赛门槛高</strong>：参赛费普遍高于其他省份</li>
<li><strong>血统集中</strong>：詹森、胡本、考夫曼等品种占比大</li>
<li><strong>分速中等</strong>：京城气候多变，赛事分速波动较大</li>
</ul>
<h2>2026关注赛事</h2>
<p>今年北京地区出现了多羽 <strong>1800+分速</strong> 的优异赛鸽，血统以詹森系为主。建议关注 <a href="/tools.php?action=top100">TOP100排行榜</a> 追踪京城最佳赛鸽动态。</p>
<p>🔍 <a href="/loft/city/北京/">浏览北京公棚目录 →</a></p>',
'images/articles/article_b3_03.svg', '信鸽之家数据引擎'),

(1, 1, '天津信鸽赛事2026赛季热门公棚推荐',
'天津2026年热门公棚横向对比：武清、北辰、津南三大赛区赛事数据，分速排行与参赛体验评测。',
'<h2>天津赛鸽高地</h2>
<p>天津作为华北赛鸽重镇，2026年吸引了大量外地鸽友参赛。信鸽之家整理了天津市 <strong>主要公棚</strong> 的赛事数据，帮助鸽友做出更明智的参赛选择。</p>
